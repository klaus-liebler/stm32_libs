/**
 * @file SigmoidAcceleration_Example.cpptemplate
 * @brief Beispielcode für die Verwendung von SigmoidStepper + SigmoidAccelerationProfile
 *
 * HINWEIS (2026): diese Datei wurde komplett neu geschrieben. Die vorherige Fassung bezog sich
 * auf eine laengst nicht mehr existierende API (SigmoidAcceleration.hpp/SigmoidLookupTables.hpp,
 * setLookupTable()/reset()/isComplete()/getNextARR(), AccelerationProfileFactory,
 * AccelerationSegment-Felder end_time/end_arr/max_deviation) -- keine dieser Klassen/Methoden/
 * Felder existiert in sigmoid_stepper.hh/sigmoid_acceleration_profile.hh. Die tatsaechliche
 * aktuelle API generiert die Step/Dir-Pulse selbst per Timer-Update-Interrupt
 * (SigmoidStepper::Handle_update_interrupt_(), aufgerufen aus dem jeweiligen TIMx_IRQHandler),
 * nicht per manuellem getNextARR()-Polling.
 */

#include "gpio.hh"
#include "sigmoid_stepper.hh"
#include "sigmoid_acceleration_profile_100_1000_5_170mhz.hh" // oder ein selbst generiertes Profil, s.u.

